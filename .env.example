# Copie para .env e preencha os valores.
# Neon: https://neon.tech → criar projeto → connection string

DATABASE_URL=postgresql://usuario:senha@host/banco?sslmode=require
JWT_SECRET=gere-uma-chave-longa-e-aleatoria-para-producao

# Só para desenvolvimento: URL do backend (ex.: Docker em localhost:3001).
# Em produção na Vercel deixe em branco (mesma origem).
# VITE_API_URL=http://localhost:3001

# Upload de foto de perfil (Vercel Blob). Crie um Blob store no projeto na Vercel (Storage).
# Local: use "vercel env pull" ou copie o token do dashboard.
# BLOB_READ_WRITE_TOKEN=
