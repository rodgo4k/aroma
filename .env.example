# ===========================================
# Copie este arquivo para .env e preencha.
# Nunca commite o .env (deve estar no .gitignore).
# ===========================================

# --- Obrigatórias para login/cadastro (email e senha) ---
DATABASE_URL=postgresql://usuario:senha@host/banco?sslmode=require
JWT_SECRET=gere-uma-chave-longa-e-aleatoria-para-producao

# --- Upload de foto de perfil (opcional) ---
# Crie um Blob store na Vercel (Storage). Sem isso, o botão "Enviar foto" não funciona.
# BLOB_READ_WRITE_TOKEN=

# --- Login com Google e Facebook (opcional) ---
# Sem essas variáveis, os botões "Google" e "Facebook" não funcionam (login por email/senha continua ok).
FRONTEND_URL=http://localhost:5173
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# --- Desenvolvimento local ---
# Só necessário se o front roda em outro endereço (ex.: Vite em localhost:5173 e API em localhost:3001).
# Em produção na Vercel deixe em branco (front e API na mesma origem).
# VITE_API_URL=http://localhost:3001
